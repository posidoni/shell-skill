# Example environment file — copy to `.env` and fill in real values.
# `.env` itself is git-ignored (see .gitignore); this template is tracked.
#
# Convention: in scripts, read these with a safe default so `set -u` does not
# abort when one is unset, e.g.  port="${APP_PORT:-8080}"

# Non-secret configuration (safe to commit as a template).
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info

# Secrets — never commit real values. Leave blank here; supply via `.env`,
# your secret manager, or the CI provider's encrypted secrets.
API_TOKEN=
DATABASE_URL=
